
{
  "name": "cypress-pom-framework",
  "version": "1.0.0",
  "description": "Framework profesional con POM y Allure",
  "main": "index.js",
  "scripts": {
    "clean:reports": "rm -rf allure-results cypress/reports",
    "cy:open": "cypress open",
    "open:qa": "cypress open --env configFile=qa",
    "test:dev": "cypress run --env configFile=dev --browser chrome",
    "test:qa": "cypress run --env configFile=qa --browser chrome",
    "test:allure:qa": "npm run allure:clear && npm run test:qa && npm run allure:report",
    "allure:clear": "rimraf allure-results allure-report",
    "cy:run:qa": "cypress run --env configFile=qa,allure=true",
    "allure:report": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "test:allure": "npm run allure:clear && npm run cy:run:qa && npm run allure:report && npm run allure:open"
  },
  "devDependencies": {
    "cypress": "^13.6.0",
    "@shelex/cypress-allure-plugin": "^2.40.0",
    "allure-commandline": "^2.24.0",
    "cypress-mochawesome-reporter": "^3.8.0",
    "fs-extra": "^11.1.1"
  },
  "dependencies": {
    "@google/generative-ai": "^0.2.0"
  }
}

